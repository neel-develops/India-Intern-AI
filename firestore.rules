rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Internships ────────────────────────────────────────────────────────────
    // Anyone can read internships (public job board)
    // Only authenticated users can create/edit/delete their OWN postings
    match /internships/{internshipId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && (resource.data.recruiterId == request.auth.uid
            || resource.data.recruiterId == null);
    }

    // ── Applications ──────────────────────────────────────────────────────────
    // Students can create applications for themselves
    // Authenticated users can read / update status
    match /applications/{applicationId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.studentEmail == request.auth.token.email;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // ── Meta (seeding flag) ────────────────────────────────────────────────────
    match /_meta/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // ── Users & Profiles ───────────────────────────────────────────────────────
    // Each user can read and write ONLY their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Notifications subcollection — same owner-only rule
      match /notifications/{notifId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
