rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Internships ────────────────────────────────────────────────────────────
    // Anyone can read internships (public job board)
    // Only authenticated recruiters can create/edit/delete their OWN postings
    // Static seed docs (recruiterId == null) can be written once during seeding
    match /internships/{internshipId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && (resource.data.recruiterId == request.auth.uid
            || resource.data.recruiterId == null);
    }

    // ── Applications ──────────────────────────────────────────────────────────
    // Students can create applications for themselves
    // Students can read their own applications
    // Anyone authenticated can read applications (recruiters see all for their internships)
    // Only authenticated users can update status
    match /applications/{applicationId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.studentEmail == request.auth.token.email;
      allow update: if request.auth != null;
      allow delete: if false; // Applications cannot be deleted
    }

    // ── Meta (seeding flag) ────────────────────────────────────────────────────
    match /_meta/{docId} {
      allow read: if true;
      allow write: if true; // Allow seeding; restrict further if needed
    }
  }
}
